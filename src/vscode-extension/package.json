{
  "name": "bce",
  "displayName": "Bicep Cost Estimator",
  "description": "Estimate monthly Azure costs from Bicep files",
  "version": "0.1.0",
  "publisher": "enginpolat",
  "repository": {
    "type": "git",
    "url": "https://github.com/polatengin/washington.git"
  },
  "author": {
    "name": "Engin Polat"
  },
  "license": "MIT",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.76.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:bicep"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Bicep Cost Estimator",
      "properties": {
        "bce.defaultRegion": {
          "type": "string",
          "default": "eastus",
          "description": "Default Azure region when not specified in resource"
        },
        "bce.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the bce CLI binary. Auto-detected if empty."
        },
        "bce.estimateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh estimates for open .bicep files"
        },
        "bce.showCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Show cost estimates as CodeLens above resources"
        },
        "bce.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show total estimated cost in the status bar"
        },
        "bce.cacheTtlHours": {
          "type": "number",
          "default": 24,
          "description": "Pricing cache time-to-live in hours"
        }
      }
    },
    "commands": [
      {
        "command": "bce.estimateFile",
        "title": "Estimate File Cost",
        "category": "Bicep Cost Estimator"
      },
      {
        "command": "bce.estimateWorkspace",
        "title": "Estimate Workspace Cost",
        "category": "Bicep Cost Estimator"
      },
      {
        "command": "bce.clearCache",
        "title": "Clear Pricing Cache",
        "category": "Bicep Cost Estimator"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "bce.estimateFile",
          "when": "editorLangId == bicep",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "bce.estimateFile",
          "when": "resourceLangId == bicep",
          "group": "0_estimation"
        }
      ],
      "commandPalette": [
        {
          "command": "bce.estimateFile"
        },
        {
          "command": "bce.estimateWorkspace"
        },
        {
          "command": "bce.clearCache"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "bceCostBreakdown",
          "name": "Cost Breakdown",
          "when": "resourceLangId == bicep || editorLangId == bicep"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "10.0.1",
    "@types/node": "18.x",
    "@types/vscode": "1.76.0",
    "@typescript-eslint/eslint-plugin": "5.56.0",
    "@typescript-eslint/parser": "5.56.0",
    "@vscode/test-electron": "2.5.2",
    "eslint": "8.36.0",
    "mocha": "10.8.2",
    "ts-loader": "9.4.2",
    "typescript": "5.0.2",
    "webpack": "5.105.4",
    "webpack-cli": "5.0.1"
  },
  "dependencies": {
    "vscode-languageclient": "8.1.0"
  }
}

{
  "name": "src-website",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "generate:playground-fixtures": "node scripts/generate-playground-fixtures.mjs",
    "generate:supported-resources": "node scripts/generate-supported-resources.mjs",
    "prestart": "node scripts/generate-playground-fixtures.mjs",
    "prebuild": "node scripts/generate-playground-fixtures.mjs && node scripts/generate-supported-resources.mjs && node scripts/generate-plain-text.mjs && node scripts/generate-search-index.mjs",
    "pretypecheck": "node scripts/generate-playground-fixtures.mjs",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "postbuild": "node scripts/generate-search-index.mjs --cleanup && node scripts/generate-plain-text.mjs --cleanup",
    "dev": "node scripts/dev.mjs",
    "preview": "npm run build && node server.mjs",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@mdx-js/react": "3.0.0",
    "clsx": "2.0.0",
    "express": "5.1.0",
    "prism-react-renderer": "2.3.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "terminal-image": "^2.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/tsconfig": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "chokidar": "3.6.0",
    "http-proxy-middleware": "2.0.9",
    "typescript": "5.6.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}

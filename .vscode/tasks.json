{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "BuildCLI",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/src/cli/cli.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch",
      "type": "process",
      "command": "dotnet",
      "args": [
        "watch",
        "run",
        "${workspaceFolder}/src/cli/cli.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "CopyCLIToBin",
      "type": "shell",
      "command": "mkdir -p ${workspaceFolder}/src/vscode-extension/bin && cp -r ${workspaceFolder}/src/cli/bin/Debug/net10.0/* ${workspaceFolder}/src/vscode-extension/bin/ && ln -sf cli ${workspaceFolder}/src/vscode-extension/bin/washington",
      "dependsOn": [
        "BuildCLI"
      ],
      "problemMatcher": []
    },
    {
      "label": "vscode-extension-compile",
      "type": "npm",
      "script": "compile",
      "path": "src/vscode-extension",
      "group": "build",
      "problemMatcher": [],
      "detail": "webpack",
      "dependsOn": [
        "CopyCLIToBin"
      ]
    }
  ]
}

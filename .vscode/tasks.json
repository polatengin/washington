{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "BuildCLI",
      "type": "shell",
      "command": "make",
      "args": [
        "build-cli"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "watch",
      "type": "process",
      "command": "dotnet",
      "args": [
        "watch",
        "--project",
        "${workspaceFolder}/src/cli/washington.csproj",
        "run"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "CopyCLIToBin",
      "type": "shell",
      "command": "rm -rf ${workspaceFolder}/src/vscode-extension/bin && mkdir -p ${workspaceFolder}/src/vscode-extension/bin && cp -r ${workspaceFolder}/src/cli/bin/Release/net10.0/. ${workspaceFolder}/src/vscode-extension/bin/ && chmod +x ${workspaceFolder}/src/vscode-extension/bin/washington || true",
      "dependsOn": [
        "BuildCLI"
      ],
      "problemMatcher": []
    },
    {
      "label": "vscode-extension-compile",
      "type": "shell",
      "command": "make",
      "args": [
        "build-extension"
      ],
      "group": "build",
      "problemMatcher": [],
      "detail": "make build-extension"
    }
  ]
}

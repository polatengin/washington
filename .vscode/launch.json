{
  "version": "2.0.0",
  "configurations": [
    {
      "name": "VSCode Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--enable-proposed-api",
        "--extensionDevelopmentPath=${workspaceRoot}/src/vscode-extension"
      ],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceRoot}/src/vscode-extension/dist/**/*.js"
      ],
      "preLaunchTask": "vscode-extension-compile"
    },
    {
      "name": "CLI",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "BuildCLI",
      "program": "${workspaceFolder}/src/cli/bin/Release/net10.0/bce.dll",
      "args": [
        "estimate",
        "--file",
        "../../tests/fixtures/all.bicep",
        "--params-file",
        "../../tests/fixtures/all.bicepparam"
      ],
      "env": {
        "BICEP_TRACING_ENABLED": "true"
      },
      "cwd": "${workspaceFolder}/src/cli",
      "console": "internalConsole",
      "stopAtEntry": false
    },
    {
      "name": "Attach",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}
